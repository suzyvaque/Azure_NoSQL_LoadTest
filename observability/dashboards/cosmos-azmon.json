      "title": "Server Side Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "bmt-azuremonitor" },
