{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmt/scenarios/schema.json",
  "title": "BMT scenario",
  "description": "Declarative load-test scenario consumed by loadgen. Mirrors Bmt.Contracts.ScenarioConfig.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "durationMinutes",
    "jobsPerHour",
    "tasksPerJob",
    "arrival",
    "workers",
    "poolSize",
    "distribution",
    "idRange",
    "thinkMsMin",
    "thinkMsMax",
    "writeConcern"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "durationMinutes": { "type": "integer", "minimum": 1 },
    "jobsPerHour": { "type": "integer", "minimum": 1 },
    "rampToJobsPerHour": { "type": "integer", "minimum": 1 },
    "tasksPerJob": { "type": "integer", "minimum": 1 },
    "arrival": { "type": "string", "enum": ["poisson"] },
    "workers": { "type": "integer", "minimum": 1 },
    "poolSize": { "type": "integer", "minimum": 1 },
    "distribution": { "type": "string", "enum": ["uniform", "zipfian"] },
    "zipfExponent": { "type": "number", "exclusiveMinimum": 0 },
    "idRange": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2,
      "maxItems": 2
    },
    "thinkMsMin": { "type": "integer", "minimum": 0 },
    "thinkMsMax": { "type": "integer", "minimum": 0 },
    "writeConcern": { "type": "string", "enum": ["w1"] },
    "warmupMinutes": { "type": "integer", "minimum": 0 },
    "warmupFractionOfTarget": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
