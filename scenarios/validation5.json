{
  "$schema": "./schema.json",
  "name": "validation5",
  "description": "5-minute validation: moderate continuous load to exercise the pipeline and populate Grafana before the full KPI run.",
  "durationMinutes": 5,
  "jobsPerHour": 1200,
  "tasksPerJob": 60,
  "arrival": "poisson",
  "workers": 100,
  "poolSize": 100,
  "distribution": "uniform",
  "idRange": [1, 1000000],
  "thinkMsMin": 50,
  "thinkMsMax": 250,
  "writeConcern": "w1",
  "warmupMinutes": 1,
  "warmupFractionOfTarget": 0.10
}
